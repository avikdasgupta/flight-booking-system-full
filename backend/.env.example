PORT=5000
NODE_ENV=development

# MongoDB Atlas (free M0 cluster — https://cloud.mongodb.com)
# Replace <username>, <password>, and <cluster> with your Atlas values.
# Use a strong password; restrict IPs in Atlas Network Access for production.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/flight_booking?retryWrites=true&w=majority

# Local MongoDB without authentication (alternative for local development without Docker)
# MONGO_URI=mongodb://localhost:27017/flight_booking

# Local MongoDB with Docker (use this when running `docker-compose up` from the /docker directory)
# The Docker container is initialised with username=admin and password=password (see docker/docker-compose.yml).
# MONGO_URI=mongodb://admin:password@localhost:27017/flight_booking?authSource=admin

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Redis Cloud free tier (https://redis.com/redis-enterprise-cloud/) or local Redis
REDIS_URL=redis://localhost:6379

# Comma-separated allowed CORS origins (add your Vercel URL in production)
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
